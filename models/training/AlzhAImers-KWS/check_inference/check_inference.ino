void setup() {
    Serial.begin(115200);
    delay(2000);

    ei_printf("Running dummy inference on static data...\n");

    signal_t signal;
    int create_signal = numpy::signal_from_buffer(dummy_input, EI_CLASSIFIER_DSP_INPUT_FRAME_SIZE, &signal);
    if (create_signal != 0) {
        ei_printf("Failed to create signal from buffer (%d)\n", create_signal);
        return;
    }

    ei_impulse_result_t result;
    EI_IMPULSE_ERROR rc = run_classifier(&signal, &result, false);
    if (rc != EI_IMPULSE_OK) {
        ei_printf("Inference failed (%d)\n", rc);
        return;
    }

    ei_printf("Predictions:\n");
    for (size_t ix = 0; ix < EI_CLASSIFIER_LABEL_COUNT; ix++) {
        ei_printf("  %s: %.4f\n",
                  result.classification[ix].label,
                  result.classification[ix].value);
    }
}

